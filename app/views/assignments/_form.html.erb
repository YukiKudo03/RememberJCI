<%# Assignment form partial %>
<%# Shared between new and edit views %>
<%# @param assignment [Assignment] The assignment object for the form %>

<%= form_with model: assignment, class: "space-y-6" do |form| %>
  <%# Error messages %>
  <% if assignment.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex items-center gap-2 mb-2">
        <svg class="h-5 w-5 text-red-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
        </svg>
        <h3 class="text-sm font-medium text-red-800">
          <%= assignment.errors.count %>件のエラーがあります
        </h3>
      </div>
      <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
        <% assignment.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Text field %>
  <div>
    <%= form.label :text_id, "テキスト", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.collection_select :text_id, Text.all, :id, :title,
        { prompt: "テキストを選択してください" },
        class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm #{assignment.errors[:text].any? ? 'border-red-300 focus:ring-red-500 focus:border-red-500' : ''}" %>
    <% if assignment.errors[:text].any? %>
      <p class="mt-1 text-sm text-red-600"><%= assignment.errors[:text].first %></p>
    <% end %>
  </div>

  <%# User field %>
  <div>
    <%= form.label :user_id, "ユーザー", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.collection_select :user_id, User.all, :id, :name,
        { prompt: "ユーザーを選択してください（任意）", include_blank: true },
        class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm #{assignment.errors[:user].any? ? 'border-red-300 focus:ring-red-500 focus:border-red-500' : ''}" %>
    <% if assignment.errors[:user].any? %>
      <p class="mt-1 text-sm text-red-600"><%= assignment.errors[:user].first %></p>
    <% end %>
  </div>

  <%# Group field %>
  <div>
    <%= form.label :group_id, "グループ", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.collection_select :group_id, Group.all, :id, :name,
        { prompt: "グループを選択してください（任意）", include_blank: true },
        class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm #{assignment.errors[:group].any? ? 'border-red-300 focus:ring-red-500 focus:border-red-500' : ''}" %>
    <% if assignment.errors[:group].any? %>
      <p class="mt-1 text-sm text-red-600"><%= assignment.errors[:group].first %></p>
    <% end %>
    <p class="mt-1 text-xs text-gray-500">ユーザーまたはグループのいずれかを選択してください</p>
  </div>

  <%# Deadline field %>
  <div>
    <%= form.label :deadline, "期限", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.datetime_local_field :deadline,
        class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm #{assignment.errors[:deadline].any? ? 'border-red-300 focus:ring-red-500 focus:border-red-500' : ''}" %>
    <% if assignment.errors[:deadline].any? %>
      <p class="mt-1 text-sm text-red-600"><%= assignment.errors[:deadline].first %></p>
    <% end %>
  </div>

  <%# Submit button %>
  <div class="flex items-center justify-end gap-3 pt-4 border-t border-gray-200">
    <%= link_to "キャンセル", assignments_path,
        class: "inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors" %>
    <%= form.submit assignment.persisted? ? "更新" : "作成",
        class: "inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-indigo-600 border border-transparent rounded-md shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors cursor-pointer" %>
  </div>
<% end %>
