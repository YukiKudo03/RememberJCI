<%# Admin edit user page %>
<%# Updates an existing user in the system %>

<div class="max-w-2xl mx-auto">
  <%# Header section %>
  <div class="mb-6">
    <nav class="flex items-center text-sm text-gray-500 mb-2" aria-label="パンくずリスト">
      <%= link_to "ユーザー管理", admin_users_path, class: "hover:text-indigo-600 transition-colors" %>
      <svg class="mx-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
      </svg>
      <%= link_to @user.name, admin_user_path(@user), class: "hover:text-indigo-600 transition-colors" %>
      <svg class="mx-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
      </svg>
      <span class="text-gray-900">編集</span>
    </nav>
    <h1 class="text-2xl font-bold text-gray-900">ユーザー編集</h1>
    <p class="mt-1 text-sm text-gray-500">
      <%= @user.name %> の情報を編集します
    </p>
  </div>

  <%# Form card %>
  <div class="bg-white shadow-sm rounded-lg p-6">
    <%= render "form", user: @user %>
  </div>
</div>
