<%# Admin new text page %>
<%# Creates a new text in the system %>

<div class="max-w-2xl mx-auto">
  <%# Header section %>
  <div class="mb-6">
    <nav class="flex items-center text-sm text-gray-500 mb-2" aria-label="パンくずリスト">
      <%= link_to "テキスト管理", admin_texts_path, class: "hover:text-indigo-600 transition-colors" %>
      <svg class="mx-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
      </svg>
      <span class="text-gray-900">新規作成</span>
    </nav>
    <h1 class="text-2xl font-bold text-gray-900">新規テキスト作成</h1>
    <p class="mt-1 text-sm text-gray-500">
      新しい暗記用テキストを作成します
    </p>
  </div>

  <%# Form card %>
  <div class="bg-white shadow-sm rounded-lg p-6">
    <%= render "form", text: @text %>
  </div>
</div>
