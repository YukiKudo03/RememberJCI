<%# Flash messages partial %>
<%# Displays flash messages with appropriate styling for each type %>
<%# Types: notice (success/green), alert (warning/yellow), error (error/red) %>

<div id="flash-messages" class="fixed top-4 right-4 z-50 flex flex-col gap-3 max-w-sm w-full pointer-events-none">
  <% flash.each do |type, message| %>
    <% next if message.blank? %>
    <%
      # Determine styling based on flash type
      case type.to_s
      when 'notice', 'success'
        bg_class = 'bg-green-100 border-green-400'
        text_class = 'text-green-700'
        icon_class = 'text-green-500'
        icon_path = 'M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z'
      when 'alert', 'warning'
        bg_class = 'bg-yellow-100 border-yellow-400'
        text_class = 'text-yellow-700'
        icon_class = 'text-yellow-500'
        icon_path = 'M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z'
      when 'error'
        bg_class = 'bg-red-100 border-red-400'
        text_class = 'text-red-700'
        icon_class = 'text-red-500'
        icon_path = 'M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z'
      else
        bg_class = 'bg-blue-100 border-blue-400'
        text_class = 'text-blue-700'
        icon_class = 'text-blue-500'
        icon_path = 'M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z'
      end
    %>
    <div class="<%= bg_class %> border <%= text_class %> px-4 py-3 rounded-lg shadow-lg pointer-events-auto flex items-start gap-3"
         role="alert"
         data-controller="flash">
      <%# Icon %>
      <svg class="flex-shrink-0 h-5 w-5 <%= icon_class %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="<%= icon_path %>" clip-rule="evenodd"/>
      </svg>

      <%# Message content %>
      <span class="flex-1 text-sm font-medium"><%= message %></span>

      <%# Dismiss button %>
      <button type="button"
              class="flex-shrink-0 ml-auto -mr-1 -mt-0.5 p-1 rounded hover:bg-black/10 transition-colors"
              data-action="click->flash#dismiss"
              aria-label="閉じる">
        <svg class="h-4 w-4 <%= icon_class %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
      </button>
    </div>
  <% end %>
</div>
