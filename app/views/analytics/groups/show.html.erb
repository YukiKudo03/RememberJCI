<%# グループ分析詳細ページ %>
<%# グループメンバーの進捗を確認する %>

<div class="space-y-6">
  <%# ヘッダーセクション %>
  <div>
    <nav class="flex items-center text-sm text-gray-500 mb-2" aria-label="パンくずリスト">
      <%= link_to "グループ分析", analytics_groups_path, class: "hover:text-indigo-600 transition-colors" %>
      <svg class="mx-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
      </svg>
      <span class="text-gray-900"><%= @group.name %></span>
    </nav>
    <h1 class="text-2xl font-bold text-gray-900"><%= @group.name %></h1>
    <p class="mt-1 text-sm text-gray-500">
      メンバー数: <%= @members.count %> 名
    </p>
  </div>

  <%# 統計サマリー %>
  <%
    avg_progress = @member_analytics.any? ? (@member_analytics.sum { |m| m[:progress_percentage] }.to_f / @member_analytics.count).round : 0
    behind_count = @member_analytics.count { |m| m[:is_behind] }
    mastered_total = @member_analytics.sum { |m| m[:texts_mastered] }
  %>
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-4">
    <div class="bg-white shadow-sm rounded-lg p-4">
      <p class="text-sm text-gray-500">メンバー数</p>
      <p class="text-2xl font-bold text-gray-900"><%= @members.count %></p>
    </div>
    <div class="bg-white shadow-sm rounded-lg p-4">
      <p class="text-sm text-gray-500">平均進捗率</p>
      <p class="text-2xl font-bold text-indigo-600"><%= avg_progress %>%</p>
    </div>
    <div class="bg-white shadow-sm rounded-lg p-4">
      <p class="text-sm text-gray-500">遅れている人数</p>
      <p class="text-2xl font-bold <%= behind_count > 0 ? 'text-red-600' : 'text-green-600' %>"><%= behind_count %></p>
    </div>
    <div class="bg-white shadow-sm rounded-lg p-4">
      <p class="text-sm text-gray-500">マスターテキスト数</p>
      <p class="text-2xl font-bold text-yellow-500"><%= mastered_total %></p>
    </div>
  </div>

  <%# メンバー一覧テーブル %>
  <div class="bg-white shadow-sm rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-medium text-gray-900">メンバー進捗</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              学習者
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              進捗率
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              最新テストスコア
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              マスターテキスト
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              ステータス
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
              操作
            </th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @member_analytics.each do |analytics| %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div>
                    <div class="text-sm font-medium text-gray-900">
                      <%= analytics[:user].name %>
                    </div>
                    <div class="text-sm text-gray-500">
                      <%= analytics[:user].email %>
                    </div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="w-16 bg-gray-200 rounded-full h-2 mr-2">
                    <div class="bg-indigo-600 h-2 rounded-full" style="width: <%= analytics[:progress_percentage] %>%"></div>
                  </div>
                  <span class="text-sm text-gray-900"><%= analytics[:progress_percentage] %>%</span>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if analytics[:latest_test_score] %>
                  <span class="text-sm font-medium <%= analytics[:latest_test_score] >= 80 ? 'text-green-600' : analytics[:latest_test_score] >= 50 ? 'text-yellow-600' : 'text-red-600' %>">
                    <%= analytics[:latest_test_score] %>点
                  </span>
                <% else %>
                  <span class="text-sm text-gray-400">-</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-sm text-gray-900"><%= analytics[:texts_mastered] %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if analytics[:is_behind] %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                    遅れ
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    順調
                  </span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to "詳細", member_analytics_group_path(@group, analytics[:user]), class: "text-indigo-600 hover:text-indigo-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# 空の状態 %>
    <% if @members.empty? %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">メンバーがいません</h3>
        <p class="mt-1 text-sm text-gray-500">このグループにはまだメンバーがいません。</p>
      </div>
    <% end %>
  </div>
</div>
