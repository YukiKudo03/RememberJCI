<%# Unified invalid invite page — shown for expired/revoked/exhausted/unknown tokens %>

<div class="max-w-md mx-auto space-y-6 pt-8 text-center">
  <svg class="mx-auto h-16 w-16 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
  </svg>

  <div>
    <h1 class="text-xl font-medium text-gray-900"><%= t("join_invites.invalid.title") %></h1>
    <p class="mt-2 text-sm text-gray-500 max-w-sm mx-auto"><%= t("join_invites.invalid.body") %></p>
  </div>

  <%= link_to t("join_invites.invalid.home_cta"), root_path,
      class: "inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
</div>
