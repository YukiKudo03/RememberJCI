<%# SidebarComponent - サイドバーナビゲーション %>
<%# ロール別のナビゲーションメニューを表示する %>

<aside
  class="w-64 bg-white border-r border-gray-200 min-h-full"
  <%= "data-controller=sidebar" if collapsible? %>
>
  <nav class="flex flex-col py-4">
    <%# メインナビゲーション %>
    <div data-section="main" class="px-3 space-y-1">
      <% main_items.each do |item| %>
        <a href="<%= item[:path] %>"
           class="flex items-center px-3 py-2 text-sm font-medium rounded-md transition-colors <%= item_classes(item) %>">
          <%= render_icon(item[:icon]) %>
          <span class="ml-3"><%= item[:label] %></span>
        </a>
      <% end %>
    </div>

    <%# 管理セクション（管理者のみ） %>
    <% if has_admin_section? %>
      <div data-section="admin" class="mt-6 px-3">
        <div class="px-3 mb-2">
          <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider">管理</span>
        </div>
        <div class="space-y-1">
          <% admin_items.each do |item| %>
            <a href="<%= item[:path] %>"
               class="flex items-center px-3 py-2 text-sm font-medium rounded-md transition-colors <%= item_classes(item) %>">
              <%= render_icon(item[:icon]) %>
              <span class="ml-3"><%= item[:label] %></span>
            </a>
          <% end %>
        </div>
      </div>
    <% end %>
  </nav>

  <%# 折りたたみボタン %>
  <% if collapsible? %>
    <div class="px-3 py-2 border-t border-gray-200">
      <button
        type="button"
        data-action="sidebar#toggle"
        class="flex items-center w-full px-3 py-2 text-sm text-gray-500 hover:text-gray-700 hover:bg-gray-50 rounded-md transition-colors"
      >
        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        <span class="ml-2">折りたたむ</span>
      </button>
    </div>
  <% end %>
</aside>
