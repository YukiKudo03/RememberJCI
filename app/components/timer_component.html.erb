<%# TimerComponent - カウントダウンタイマー表示 %>
<%# 要件参照: FR-54 (制限時間付きテストのサポート) %>

<div
  <% stimulus_data.each do |key, value| %>data-<%= key %>="<%= value %>" <% end %>
  class="inline-flex items-center px-4 py-2 bg-gray-100 rounded-lg <%= size_classes %>"
  role="timer"
  aria-live="polite"
  aria-label="残り時間"
>
  <% if show_icon? %>
    <svg class="h-5 w-5 text-gray-500 mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
    </svg>
  <% end %>
  <span
    data-timer-target="display"
    class="font-mono text-gray-700 transition-colors duration-300"
  >
    <%= formatted_time %>
  </span>
</div>
